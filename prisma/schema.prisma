// Prisma schema for Pragunpai.com
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Admin accounts (client owner + support)
// ---------------------------------------------------------------------------
model Admin {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  otpCodeHash    String? // hashed email OTP for 2FA
  otpExpiresAt   DateTime?
  resetTokenHash String? // hashed password-reset token
  resetExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Lead — customer quote request
// ---------------------------------------------------------------------------
enum LeadStatus {
  NEW
  CONTACTED
  AWAITING_DOCS
  QUOTED
  CLOSED
  NOT_INTERESTED
  SPAM
}

enum LeadFormType {
  CAR_ACT
  ACCIDENT
  PROPERTY
  OTHER
}

model Lead {
  id          String          @id @default(cuid())
  formType    LeadFormType
  name        String
  phone       String
  lineId      String?
  province    String?
  details     Json? // type-specific fields, e.g. carType, assetValue, budget...
  attachments LeadAttachment[]
  status      LeadStatus      @default(NEW)
  notes       String?
  emailSent   Boolean         @default(true)
  emailError  String?
  expiresAt   DateTime // PDPA: auto-purge after 30 days
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([formType])
  @@index([createdAt])
  @@index([expiresAt])
}

model LeadAttachment {
  id        String   @id @default(cuid())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  url       String
  filename  String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Insurance product pages (dynamic, admin-managed)
// ---------------------------------------------------------------------------
enum InsuranceType {
  CAR_ACT
  ACCIDENT
  PROPERTY
}

model InsurancePage {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  type            InsuranceType
  bannerImage     String?
  bannerAlt       String?
  summary         String
  coverage        String           @db.Text
  premium         String
  conditions      String?          @db.Text
  pdfUrl          String?
  seoTitle        String?
  metaDescription String?
  keywords        String?
  published       Boolean          @default(true)
  comparisonTable ComparisonTable?
  articles        Article[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([type])
}

// ---------------------------------------------------------------------------
// Comparison tables (admin-managed, shown on product pages)
// ---------------------------------------------------------------------------
model ComparisonTable {
  id             String         @id @default(cuid())
  insurancePage  InsurancePage? @relation(fields: [insurancePageId], references: [id], onDelete: Cascade)
  insurancePageId String?       @unique
  rows           PlanRow[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PlanRow {
  id           String          @id @default(cuid())
  table        ComparisonTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId      String
  coverageItem String
  // plan columns as JSON: { "แผนเงินคุ้มครอง": "100,000 บาท", "แผนเงินคุ้มครองสูงสุด": "200,000 บาท" }
  planValues   Json
  order        Int             @default(0)
}

// ---------------------------------------------------------------------------
// Articles (SEO content, topic clusters)
// ---------------------------------------------------------------------------
enum ArticleCategory {
  CAR_ACT
  ACCIDENT
  PROPERTY
  GENERAL
  FAQ
}

model Article {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  excerpt         String
  content         String          @db.Text
  coverImage      String?
  coverAlt        String?
  category        ArticleCategory @default(GENERAL)
  insurancePage   InsurancePage?  @relation(fields: [insurancePageId], references: [id], onDelete: SetNull)
  insurancePageId String?
  seoTitle        String?
  metaDescription String?
  keywords        String?
  publishedAt     DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category])
  @@index([publishedAt])
}

// ---------------------------------------------------------------------------
// FAQ items (FAQPage JSON-LD, shown on home & insurance pages)
// ---------------------------------------------------------------------------
model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  category  String? // "home", "car-act", "accident", "general"...
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// SEO meta for static pages
// ---------------------------------------------------------------------------
model SeoMeta {
  id              String   @id @default(cuid())
  pageKey         String   @unique // "home", "about", "contact", "privacy"...
  seoTitle        String
  metaDescription String
  keywords        String?
  updatedAt       DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Site-wide settings (contact, hero, floating buttons, NAP, tracking)
// ---------------------------------------------------------------------------
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // "contact", "hero", "floatingButtons", "nap", "tracking"
  value     Json
  updatedAt DateTime @updatedAt
}
