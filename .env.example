# ---------------------------------------------------------------------------
# Pragunpai.com — Environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# Database (PostgreSQL) — for Docker Compose deployment
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable"

# PostgreSQL container credentials (used by postgres docker image)
POSTGRES_USER=pragunpai
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=pragunpai

# Auth.js (NextAuth v5)
# Generate: `openssl rand -base64 32`
AUTH_SECRET="change-me-to-a-long-random-string"
# Where the app runs (no trailing slash)
AUTH_URL="http://localhost:3000"

# Resend (transactional email — lead alerts + email OTP)
RESEND_API_KEY="re_xxxxxxxxxxxx"
# From-address used for outbound transactional email
EMAIL_FROM="Pragunpai <no-reply@pragunpai.com>"
# Mailbox that receives lead-alert emails
LEAD_ALERT_TO="service@pragunpai.com"

# Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your_site_key"
RECAPTCHA_SECRET_KEY="your_secret_key"

# Object storage (Cloudflare R2 or Supabase Storage) for lead attachments
# (If using local dev fallback, leave blank to store under /public/uploads dev-only)
S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="pragunpai-attachments"
S3_ACCESS_KEY_ID="xxx"
S3_SECRET_ACCESS_KEY="xxx"
S3_PUBLIC_BASE_URL="https://media.pragunpai.com"

# Public brand/site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Pragunpai"

# Brand contact (used across site + JSON-LD LocalBusiness / NAP)
NEXT_PUBLIC_PHONE="0819416620"
NEXT_PUBLIC_LINE="0819416620"
NEXT_PUBLIC_EMAIL="service@pragunpai.com"

# Google Analytics 4 measurement ID (G-XXXX)
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification token (without "google" prefix)
NEXT_PUBLIC_GSC_VERIFICATION=""

# Vercel Cron secret (used to protect /api/cron/* endpoints)
CRON_SECRET="change-me"
